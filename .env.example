# Database - PostgreSQL (Supabase / Neon / Vercel Postgres)
# For Supabase: Settings > Database > Connection string > Transaction pooler
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?pgbouncer=true&connection_limit=1"

# Direct connection URL (untuk prisma migrate, tanpa pgbouncer)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME"

# JWT Secret - gunakan string random yang kuat di production
JWT_SECRET="change-me-to-a-strong-random-secret"

# App URL
APP_URL="https://your-app.vercel.app"
